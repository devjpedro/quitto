{
  "name": "@quitto/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir dist",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "cron:reminders": "bun run src/cron/reminders.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@elysiajs/cors": "latest",
    "@quitto/shared": "workspace:*",
    "@sentry/bun": "^10.59.0",
    "better-auth": "latest",
    "drizzle-orm": "latest",
    "elysia": "1.4.28",
    "pdfkit": "^0.19.1",
    "postgres": "latest",
    "resend": "^6.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@elysiajs/eden": "latest",
    "@types/bun": "latest",
    "@types/pdfkit": "^0.17.6",
    "drizzle-kit": "latest",
    "typescript": "latest"
  }
}
